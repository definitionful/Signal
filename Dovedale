    Callback = function()
        if not isDovedaleActive then
            Fluent:Notify({ Title = "Access Denied", Content = "You are not currently hosting the Dovedale East Box.", Duration = 4 })
            return
        end

        task.spawn(function()
            local signalSystems = workspace:FindFirstChild("Interlocking_Switches/Signals")
            local leverFrames = signalSystems and signalSystems:FindFirstChild("Leverframes")
            local frameDE = leverFrames and leverFrames:FindFirstChild("DE")

            if not frameDE then
                Fluent:Notify({ Title = "Error", Content = "The Dovedale East lever frame could not be located.", Duration = 4 })
                return
            end

            local requiredLevers = {"DE_27", "DE_30", "DE_31", "DE_33", "DE_43"}

            for _, name in ipairs(requiredLevers) do
                local lever = frameDE:FindFirstChild(name)
                local pulled = lever and lever:FindFirstChild("Values") and lever.Values:FindFirstChild("Pulled")
                
                if not pulled or pulled.Value == true then
                    Fluent:Notify({ Title = "Notice", Content = "One or more required levers are already active. Please reset the frame first.", Duration = 5 })
                    return
                end
            end

            local leverSequence = {}
            if math.random() > 0.5 then
                table.insert(leverSequence, "DE_27")
                table.insert(leverSequence, "DE_30")
            else
                table.insert(leverSequence, "DE_30")
                table.insert(leverSequence, "DE_27")
            end
            
            table.insert(leverSequence, "DE_31")
            table.insert(leverSequence, "DE_33")
            table.insert(leverSequence, "DE_43")

            for _, leverName in ipairs(leverSequence) do
                local success = pullLeverToState(frameDE, leverName, true)
                if not success then
                    Fluent:Notify({ Title = "Notice", Content = string.format("Failed to interact with %s. Sequence aborted.", leverName), Duration = 4 })
                    return
                end
                task.wait(math.random(4, 9) / 10)
            end

            Fluent:Notify({ Title = "Routing Complete", Content = "Dispatching train from Satus to Platform 2.", Duration = 5 })
