local function updateBoxState()
    local hostUI = PlayerGui:FindFirstChild("BoxHostUI")
    if hostUI and hostUI.Enabled then
        local manageBox = hostUI:FindFirstChild("ManageBox")
        local title = manageBox and manageBox:FindFirstChild("Header") and manageBox.Header:FindFirstChild("Title")
        if title and title.Text == "DE Box" then
