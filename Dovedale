local function getLiteralBoxData(id)
    local boxSystem = workspace:FindFirstChild("BoxSystem")
    local targetBox = boxSystem and boxSystem:FindFirstChild(id)
    if not targetBox then return end

    local minXP = targetBox:FindFirstChild("MinXP")
    local dataFolder = targetBox:FindFirstChild("Data")
    local boxHost = dataFolder and dataFolder:FindFirstChild("BoxHost")
    local tpOut = targetBox:FindFirstChild("TpOut")
    local prompt = tpOut and tpOut:FindFirstChildOfClass("ProximityPrompt")

    if minXP and boxHost and tpOut then
        return minXP.Value, boxHost.Value, tpOut, prompt
    end
end

