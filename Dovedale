local function isPlayerInsideBox()
    local hostUI = PlayerGui:FindFirstChild("BoxHostUI")
    if hostUI then
        local manageBox = hostUI:FindFirstChild("ManageBox")
        if manageBox then
            local exitFrame = manageBox:FindFirstChild("Exit")
            if exitFrame then
                local buttons = exitFrame:FindFirstChild("Buttons")
                if buttons then
                    local leaveBtn = buttons:FindFirstChild("Leave")
                    local goBackBtn = buttons:FindFirstChild("GoBack")
                    if leaveBtn and goBackBtn then
                        if leaveBtn.Visible == false and goBackBtn.Visible == true then
                            return false
                        end
                    end
                end
            end
        end
    end
    return true
end

