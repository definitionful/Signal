local isProcessing = false

BoxToggle:OnChanged(function(State)
    if not State or isProcessing then return end
    isProcessing = true

    task.spawn(function()
        while BoxToggle.Value do
            local success, err = pcall(function()
                local inMenu = LocalPlayer:FindFirstChild("InMenu")
                if inMenu and inMenu.Value then
                    if Messages then Messages.MenuWarning() end
                    return "STOP"
                end

                local activeSelections = {}
                for _, data in ipairs(LocationData) do
                    if BoxDropdown.Value[data.Name] then
                        table.insert(activeSelections, data)
                    end
                end

                if #activeSelections == 0 then
                    if Messages then Messages.SelectLocation() end
                    return "STOP"
                end

                local hostUI = PlayerGui:FindFirstChild("BoxHostUI")
                if hostUI and hostUI.Enabled then
                    if Messages then Messages.AlreadyHosting() end
                    return "STOP"
                end

                local xpObj = LocalPlayer:FindFirstChild("Highest_XP")
                local playerXP = xpObj and xpObj.Value or 0
                local meetsAnyRequirement = false

                for _, boxData in ipairs(activeSelections) do
                    local minXP, currentHost, tpOut, prompt = getLiteralBoxData(boxData.ID)

                    if minXP and playerXP >= minXP then
                        meetsAnyRequirement = true
                        if currentHost == "" or currentHost == nil then
                            local char = LocalPlayer.Character
                            local hrp = char and char:FindFirstChild("HumanoidRootPart")
                            local humanoid = char and char:FindFirstChildOfClass("Humanoid")

                            if hrp and tpOut then
                                if humanoid and humanoid.Sit then
                                    humanoid.Jump = true
                                    task_wait(0.2)
                                end
                                
                                hrp.CFrame = tpOut:GetPivot()
                                task_wait(0.6)

                                if prompt then
                                    prompt.Enabled = true
                                    fireproximityprompt(prompt)
                                end

                                if Messages then Messages.Assigning(boxData.Name) end
                                task_wait(2.2)

                                local updatedHostUI = PlayerGui:FindFirstChild("BoxHostUI")
                                if updatedHostUI and updatedHostUI.Enabled then
                                    if Messages then Messages.AssignSuccess(boxData.Name) end
                                    return "STOP"
                                end
                            end
                        end
                    end
                end

                if not meetsAnyRequirement then
                    if Messages then Messages.XPTooLow() end
                    return "STOP"
                end
            end)

            if success and err == "STOP" then
                BoxToggle:SetValue(false)
                break
            elseif not success then
                task_wait(1)
            else
                task_wait(3)
            end
        end
        isProcessing = false
    end)
end)

local function pullLeverToState(frameDE, leverName, targetState)
    local lever = frameDE:FindFirstChild(leverName)
    if not lever then return false end

    local valuesFolder = lever:FindFirstChild("Values")
    local pulled = valuesFolder and valuesFolder:FindFirstChild("Pulled")
    local clickDetector = lever:FindFirstChildWhichIsA("ClickDetector")

    if pulled and clickDetector then
        if pulled.Value ~= targetState then
            
            if targetState == true and InterlockingModule and InterlockingModule.Boxes and InterlockingModule.Boxes.DE.LeverConfig then
                local config = InterlockingModule.Boxes.DE.LeverConfig[leverName]
                if config and config.ReleaseName then
                    local releaseNode = frameDE:FindFirstChild(config.ReleaseName)
                    if releaseNode then
                        local releaseValues = releaseNode:FindFirstChild("Values")
                        local isPressed = releaseValues and releaseValues:FindFirstChild("Pressed")
                        local releaseButton = releaseNode:FindFirstChild("Button")
                        local releaseClick = releaseButton and releaseButton:FindFirstChildOfClass("ClickDetector")

                        if isPressed and releaseClick and isPressed.Value == false then
                            fireclickdetector(releaseClick)
                            local releaseTimeout = os_clock() + 3
                            while isPressed.Value == false and os_clock() < releaseTimeout do
                                task_wait()
                            end
                        end
                    end
                end
            end

            fireclickdetector(clickDetector)
            
            local timeout = os_clock() + 5
            while pulled.Value ~= targetState and os_clock() < timeout do
                task_wait()
            end
            
            return pulled.Value == targetState
        end
        return true 
    end
    return false
end

local function executeRoute(routeKey, originName, platformName)
    if not Messages then return end

    if not isDovedaleActive then
        Messages.NotHosting("Dovedale East")
        return
    end

    if not InterlockingModule or not InterlockingModule.Boxes or not InterlockingModule.Boxes.DE.Routes then
        Messages.DataMissing()
        return
    end

    local routeData = InterlockingModule.Boxes.DE.Routes[routeKey]
    if not routeData then
        Messages.RouteNotFound(routeKey)
        return
    end

    task.spawn(function()
        local signalSystems = Workspace:FindFirstChild("Interlocking_Switches/Signals")
        local leverFrames = signalSystems and signalSystems:FindFirstChild("Leverframes")
        local frameDE = leverFrames and leverFrames:FindFirstChild("DE")

        if not frameDE then
            Messages.NoFrame("Dovedale East")
            return
        end

        for _, name in ipairs(routeData.RequiredLevers) do
            local lever = frameDE:FindFirstChild(name)
            local pulled = lever and lever:FindFirstChild("Values") and lever.Values:FindFirstChild("Pulled")
            
            if not pulled or pulled.Value == true then
                Messages.LeversActive()
                return
            end
        end

        local leverSequence = {}
        for _, step in ipairs(routeData.Sequence) do
            if step.Group then
                local shuffled = {unpack(step.Group)}
                for i = #shuffled, 2, -1 do
                    local j = math_random(i)
                    shuffled[i], shuffled[j] = shuffled[j], shuffled[i]
                end
                for _, leverName in ipairs(shuffled) do
                    table.insert(leverSequence, leverName)
                end
            end
        end

        for _, leverName in ipairs(leverSequence) do
            local success = pullLeverToState(frameDE, leverName, true)
            if not success then
                Messages.LeverFailed(leverName)
                return
            end
            task_wait(math_random(4, 9) / 10)
        end

        Messages.RoutingComplete(originName, platformName)
    end)
end

local function checkDECrossing()
    local crossing = Workspace:FindFirstChild("DECrossing")
    if not crossing then return false end
    
    local active = crossing:FindFirstChild("Active")
    local free = crossing:FindFirstChild("Free")
    
    if active and free and active.Value == true and free.Value == true then
        return true
    end
    return false
end

