local function checkDECrossing()
    local crossing = Workspace:FindFirstChild("DECrossing")
    if crossing and crossing:FindFirstChild("Active") and crossing:FindFirstChild("Free") then
        if crossing.Active.Value and crossing.Free.Value then return true end
    end
    return false, "The Dovedale East Level Crossing has not been secured."
end

local function checkDCClearance()
    local telegraph = Workspace:FindFirstChild("PenguinTelegraph")
    if telegraph and telegraph:FindFirstChild("DE - DC") and telegraph["DE - DC"]:FindFirstChild("DC") then
        local state = telegraph["DE - DC"].DC:FindFirstChild("State")
        if state and state.Value == 1 then return true end
    end
    return false, "The Telegraph Block to Dovedale Central has not been cleared."
end

local function checkSATClearance()
    local block = Workspace:FindFirstChild("TokenlessBlocks DE - SAT")
    if block and block:FindFirstChild("States") and block.States:FindFirstChild("Dial") then
        if block.States.Dial.Value == 3 then return true end
    end
    return false, "The Tokenless Block to Satus has not been cleared."
end

local function checkCHClearance()
    local block = Workspace:FindFirstChild("TokenlessBlocks DE - CH")
    if block and block:FindFirstChild("States") and block.States:FindFirstChild("Dial") then
        if block.States.Dial.Value == 3 then return true end
    end
    return false, "The Tokenless Block to Cosdale Harbour has not been cleared."
end

