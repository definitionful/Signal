-- 1. Dynamic Lever Management (Eliminating Hardcoding)
Tabs.DE:AddButton({
    Title = "Reset Lever Frame",
    Description = "Safely returns all active levers to default in strict interlocking order.",
    Callback = function()
        if not isDovedaleActive then
            Fluent:Notify({ Title = "Access Denied", Content = "You are not currently hosting the Dovedale East Box.", Duration = 4 })
            return
        end

        for _, isLocked in pairs(LeverLocks) do
            if isLocked then
                Fluent:Notify({ Title = "Please Wait", Content = "Routes are currently being set. Cannot reset frame.", Duration = 4 })
                return
            end
        end

        task.spawn(function()
            local leverConfig = InterlockingModule.Boxes.DE.LeverConfig
            
            -- Dynamically lock all configured levers
            for leverName, _ in pairs(leverConfig) do
                LeverLocks[leverName] = true
            end

            local signalSystems = Workspace:FindFirstChild("Interlocking_Switches/Signals")
            local leverFrames = signalSystems and signalSystems:FindFirstChild("Leverframes")
            local frameDE = leverFrames and leverFrames:FindFirstChild("DE")

            if not frameDE then
                Fluent:Notify({ Title = "Error", Content = "The Dovedale East lever frame could not be located.", Duration = 4 })
                for leverName, _ in pairs(leverConfig) do LeverLocks[leverName] = false end
                return
            end

            local activeLevers = {}
            for leverName, config in pairs(leverConfig) do
                local lever = frameDE:FindFirstChild(leverName)
                if lever then
                    local pulled = lever:FindFirstChild("Values") and lever.Values:FindFirstChild("Pulled")
                    if pulled and pulled.Value == true then
                        local priority = config.ResetPriority or (InterlockingModule.Boxes.DE.DefaultPriority or 5)
                        table.insert(activeLevers, { Name = leverName, Priority = priority })
                    end
                end
            end

            table.sort(activeLevers, function(a, b)
                return a.Priority < b.Priority
            end)

            for _, data in ipairs(activeLevers) do
                print(string.format("Resetting: %s | Assumed Priority: %s", data.Name, tostring(data.Priority)))
                pullLeverToState(frameDE, data.Name, false)
                task_wait(math_random(4, 9) / 10)
            end

            Fluent:Notify({ Title = "Reset Complete", Content = "Levers reset successfully in interlocking order.", Duration = 4 })
            task_wait(2)
            
            -- Dynamically unlock
            for leverName, _ in pairs(leverConfig) do
                LeverLocks[leverName] = false
            end
        end)
    end
})

